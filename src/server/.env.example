# Ledgerly Server — Environment Variables
# Copy to .env and fill in values

# Plaid credentials (from https://dashboard.plaid.com/team/keys)
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
PLAID_ENV=sandbox
# Set to: sandbox | development | production

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ledgerly

# Server port (default: 3210)
PORT=3210

# Environment
NODE_ENV=development

# CORS — set to your Electron app origin in production
# CORS_ORIGIN=*
